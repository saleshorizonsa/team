generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

enum LeadSource {
  REFERRAL
  WEBSITE
  CALL
  WALK_IN
  OTHER
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum DealStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum PayoutStatus {
  PENDING
  PAID
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  LOGIN
  PAYOUT
  SETTINGS_CHANGE
  RETURN
  ZOHO_IMPORT
}

enum CommissionType {
  EARNING
  CLAWBACK
}

enum DealSource {
  MANUAL
  ZOHO_IMPORT
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                     String   @id @default(cuid())
  fullName               String
  email                  String   @unique
  passwordHash           String
  role                   Role     @default(USER)
  commissionSharePercent Decimal? @db.Decimal(5, 2)
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  createdCustomers Customer[]
  createdSuppliers Supplier[]
  ownedLeads       Lead[]       @relation("LeadOwner")
  createdDeals     Deal[]       @relation("DealCreatedBy")
  salespersonDeals Deal[]       @relation("DealSalesperson")
  approvedDeals    Deal[]       @relation("DealApprovedBy")
  commissions      Commission[]
  auditLogs        AuditLog[]
  createdReturns   Return[]
  zohoConnections  ZohoConnection[]
  notifications    Notification[]
}

model Customer {
  id            String    @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  vatNumber     String?
  notes         String?   @db.Text
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  createdBy User   @relation(fields: [createdById], references: [id])
  deals     Deal[]
  leads     Lead[]
}

model Supplier {
  id            String    @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  vatNumber     String?
  notes         String?   @db.Text
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  createdBy User   @relation(fields: [createdById], references: [id])
  deals     Deal[]
}

model Lead {
  id              String     @id @default(cuid())
  title           String
  customerId      String?
  contactName     String?
  phone           String?
  email           String?
  source          LeadSource
  stage           LeadStage  @default(NEW)
  estimatedValue  Decimal    @db.Decimal(12, 2)
  ownerId         String
  notes           String?    @db.Text
  lostReason      String?
  convertedDealId String?    @unique
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  owner         User      @relation("LeadOwner", fields: [ownerId], references: [id])
  customer      Customer? @relation(fields: [customerId], references: [id])
  // FK on Lead → points to the Deal this lead was converted into
  convertedDeal Deal?     @relation("LeadConversion", fields: [convertedDealId], references: [id])
  // back-reference: Deals that were sourced from this lead (via Deal.leadId)
  sourcedDeals  Deal[]    @relation("DealSource")

  @@index([ownerId])
  @@index([stage])
}

model Deal {
  id             String     @id @default(cuid())
  dealNumber     String     @unique
  customerId     String
  supplierId     String?
  salespersonId  String
  leadId         String?
  salesTotal     Decimal    @db.Decimal(12, 2)
  purchaseTotal  Decimal    @db.Decimal(12, 2)
  transportation Decimal    @db.Decimal(12, 2) @default(0)
  vatRatePercent Decimal    @db.Decimal(5, 2)  @default(15)
  vatAmount      Decimal    @db.Decimal(12, 2)
  profit         Decimal    @db.Decimal(12, 2)
  status         DealStatus @default(DRAFT)
  approvedById   String?
  approvedAt     DateTime?
  rejectReason   String?    @db.Text
  notes          String?    @db.Text
  dealDate       DateTime
  source            DealSource @default(MANUAL)
  zohoInvoiceId     String?    @unique
  zohoInvoiceNumber String?
  creditedUserIds   Json?      // userIds sharing the sales pool (equal split); falls back to [salespersonId]
  createdById    String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  customer    Customer     @relation(fields: [customerId], references: [id])
  supplier    Supplier?    @relation(fields: [supplierId], references: [id])
  salesperson User         @relation("DealSalesperson", fields: [salespersonId], references: [id])
  approvedBy  User?        @relation("DealApprovedBy", fields: [approvedById], references: [id])
  createdBy   User         @relation("DealCreatedBy", fields: [createdById], references: [id])
  // FK on Deal → which lead sourced this deal
  lead        Lead?        @relation("DealSource", fields: [leadId], references: [id])
  // back-reference: if this deal is the conversion target of a lead
  fromLead    Lead?        @relation("LeadConversion")
  commissions Commission[]
  returns     Return[]

  @@index([status])
  @@index([createdById])
  @@index([salespersonId])
  @@index([dealDate])
}

model Return {
  id                  String   @id @default(cuid())
  returnNumber        String   @unique
  dealId              String
  returnDate          DateTime
  returnedSalesAmount Decimal  @db.Decimal(12, 2)
  costRecovered       Decimal  @db.Decimal(12, 2)
  returnCosts         Decimal  @db.Decimal(12, 2) @default(0)
  reversedProfit      Decimal  @db.Decimal(12, 2)
  reason              String?  @db.Text
  createdById         String
  createdAt           DateTime @default(now())

  deal        Deal         @relation(fields: [dealId], references: [id])
  createdBy   User         @relation(fields: [createdById], references: [id])
  commissions Commission[]

  @@index([dealId])
  @@index([returnDate])
}

model Commission {
  id           String         @id @default(cuid())
  dealId       String
  returnId     String?        // set on CLAWBACK lines
  userId       String
  role         Role
  type         CommissionType @default(EARNING)
  percent      Decimal        @db.Decimal(5, 2)
  amount       Decimal        @db.Decimal(12, 2) // NEGATIVE for CLAWBACK
  period       String         // "YYYY-MM", e.g. "2026-05"
  payoutStatus PayoutStatus   @default(PENDING)
  paidAt       DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  deal   Deal    @relation(fields: [dealId], references: [id])
  user   User    @relation(fields: [userId], references: [id])
  return Return? @relation(fields: [returnId], references: [id])

  @@index([dealId])
  @@index([returnId])
  @@index([userId])
  @@index([period])
  @@index([payoutStatus])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ZohoConnection {
  id                   String    @id @default(cuid())
  organizationId       String?
  apiDomain            String?   // e.g. https://www.zohoapis.sa  (auto-detected)
  accountsDomain       String?   // e.g. https://accounts.zoho.sa (auto-detected)
  refreshTokenEnc      String    @db.Text // encrypted at rest (AES-256-GCM)
  accessToken          String?   @db.Text // transient cache
  accessTokenExpiresAt DateTime?
  scopes               String?   @db.Text
  isActive             Boolean   @default(true)
  connectedById        String
  connectedAt          DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  connectedBy User @relation(fields: [connectedById], references: [id])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // DEAL_SUBMITTED | DEAL_APPROVED | DEAL_REJECTED
  message   String    @db.Text
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@index([createdAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String
  action     AuditAction
  entityType String
  entityId   String
  before     Json?
  after      Json?
  createdAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
