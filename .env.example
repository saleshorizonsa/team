# ─── Database ────────────────────────────────────────────────────────────────
# Hostinger MySQL: use localhost if the app and DB share the same account.
# Enable Remote MySQL + whitelist the server IP if they are separate.
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME"

# ─── Auth.js (NextAuth v5) ───────────────────────────────────────────────────
# Generate a strong secret: `openssl rand -base64 32`
# NextAuth v5 reads AUTH_SECRET automatically; NEXTAUTH_SECRET is the fallback.
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"
AUTH_SECRET="replace-with-a-strong-random-secret"

# Full URL of the deployed app (no trailing slash).
# In development: http://localhost:3000
NEXTAUTH_URL="https://your-domain.com"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ─── Seed ────────────────────────────────────────────────────────────────────
# Used only by prisma/seed.ts to create the initial admin account.
SEED_ADMIN_EMAIL="shareef6695@gmail.com"
SEED_ADMIN_PASSWORD="replace-with-strong-seed-password"

# Set to "true" to also insert sample customers/suppliers/leads/deals/commissions
# when running the seed. Leave unset (or "false") for a clean production database.
SEED_SAMPLE_DATA="false"

# ─── Encryption (secrets at rest) ────────────────────────────────────────────
# Strong random string; encrypts the Zoho refresh token (AES-256-GCM).
# Generate: openssl rand -base64 32
ENCRYPTION_KEY="replace-with-a-strong-random-secret"

# ─── Zoho Books (OAuth — read-only invoice import) ───────────────────────────
# Create a "Server-based Applications" client in the Zoho API console
# (https://api-console.zoho.com). Data-center domains are auto-detected at
# runtime from the OAuth response — do NOT hardcode .com/.sa/etc.
ZOHO_CLIENT_ID=""
ZOHO_CLIENT_SECRET=""
ZOHO_REDIRECT_URI="https://your-domain.com/api/zoho/callback"
# Accounts server of the DC where you created the OAuth client (the client is
# DC-bound). Saudi = https://accounts.zoho.sa, global = https://accounts.zoho.com.
# API/Books domain is still auto-detected from the token response.
ZOHO_ACCOUNTS_DOMAIN="https://accounts.zoho.com"
