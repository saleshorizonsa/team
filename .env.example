# ─── Database ────────────────────────────────────────────────────────────────
# Hostinger MySQL: use localhost if the app and DB share the same account.
# Enable Remote MySQL + whitelist the server IP if they are separate.
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME"

# ─── Auth.js (NextAuth v5) ───────────────────────────────────────────────────
# Generate a strong secret: `openssl rand -base64 32`
# NextAuth v5 reads AUTH_SECRET automatically; NEXTAUTH_SECRET is the fallback.
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"
AUTH_SECRET="replace-with-a-strong-random-secret"

# Full URL of the deployed app (no trailing slash).
# In development: http://localhost:3000
NEXTAUTH_URL="https://your-domain.com"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ─── Seed ────────────────────────────────────────────────────────────────────
# Used only by prisma/seed.ts to create the initial admin account.
SEED_ADMIN_EMAIL="shareef6695@gmail.com"
SEED_ADMIN_PASSWORD="replace-with-strong-seed-password"
